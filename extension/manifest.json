{
    "manifest_version": 3,
    "name": "Dealora Cookie Sync",
    "version": "1.0.0",
    "description": "Internal tool — sync merchant session cookies to the Dealora backend.",

    "action": {
        "default_popup": "popup.html",
        "default_icon": {
            "16":  "icons/icon16.png",
            "48":  "icons/icon48.png",
            "128": "icons/icon128.png"
        },
        "default_title": "Dealora Cookie Sync"
    },

    "background": {
        "service_worker": "background.js"
    },

    "permissions": [
        "cookies",
        "activeTab",
        "storage",
        "tabs"
    ],

    "host_permissions": [
        "<all_urls>"
    ],

    "icons": {
        "16":  "icons/icon16.png",
        "48":  "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}
