# Full connection string (Atlas: mongodb+srv://user:pass@cluster/...)
MONGODB_URI=mongodb://127.0.0.1:27017/dealora
PORT=8000

# List dashboard users in DB: npm run db:list-dashboard-users

# Comma-separated browser origins allowed to call the API with credentials
CORS_ORIGIN=http://localhost:5173

# Required for dashboard auth (use a long random string in real deployments)
DASHBOARD_JWT_SECRET=replace-with-at-least-32-random-characters

# Required for AI automation and extraction
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: access token lifetime in seconds (default 28800 = 8h)
# DASHBOARD_ACCESS_TTL_SECONDS=28800

# Optional overrides for seed:dashboard-user (otherwise built-in dev defaults apply)
# DASHBOARD_ADMIN_EMAIL=admin@dealora.local
# DASHBOARD_ADMIN_PASSWORD=
